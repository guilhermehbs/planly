PLANLY_ENV=development
PLANLY_HOST=127.0.0.1
PLANLY_PORT=8000
PLANLY_DB_PATH=./planejamento_financeiro.db
DATABASE_URL=
PLANLY_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5175,http://localhost:5175
PLANLY_SESSION_COOKIE_NAME=planly_session
PLANLY_SESSION_TTL_HOURS=12
PLANLY_SESSION_COOKIE_SAMESITE=Lax
PLANLY_COOKIE_SECURE=false
PLANLY_PUBLIC_ERROR_DETAILS=false
PLANLY_REQUIRE_CSRF=true
PLANLY_MAX_REQUEST_BYTES=262144
PLANLY_ALLOW_SQLITE_IN_PRODUCTION=false

# Defina estes valores somente no ambiente local/producao.
# Nunca versione e-mail ou senha reais.
PLANLY_ADMIN_EMAIL=
PLANLY_ADMIN_PASSWORD=

# Frontend
VITE_API_URL=http://127.0.0.1:8000/api
